package capitulo2;

import java.util.Scanner;
import capitulo6.MaximumFinder;

public class Prov {
	
	// Método que calcula o quadrado de um número inteiro
	public static int square(int x) {
		return x * x;
	}

    public static void main(String[] args) {    	    	
    	   	
    	double valor1 = 7.9;
    	double valor2 = 3.2;
    	
    	// Transformando double em int antes de chamar square
    	int resultado1 = square((int) valor1); //vira 7;
    	int resultado2 = square((int) valor2); //vira 3
    	
    	System.out.println("Quadrado de 7.9 (como int): " + resultado1);
    	System.out.println("Quadrado de 3.2 (como int): " + resultado2);
    }
}
