package exercicioCapitulo5;

public class Questao5p22 {
	
	public static void main(String[] args) {
		
		// Cabeçalho opcional para alinhar os triângulos
		System.out.println("  (A)\t\t  (B)\t\t  (C)\t\t  (D)");
		System.out.println("-----------------------------------------------------------------------------------------");
		
		// LOOP PRINCIPAL: Controla as 10 linhas do desenho
		for (int i = 1; i <= 10; i++) {
			
			//--- 1. OPERÁRIO DO TRIÂNGULO A ---
			for (int j = 1; j <= i; j++) {
				System.out.print("*");
			}
			// Espaço fixo (pode usar \t) para separar o triângulo A do B
			System.out.print("\t\t");
			
			// --- 2. OPERÁRIO DO TRIÂNGULO B ---
			for (int j = 1; j <= (11 - i); j++) {
				System.out.print("*");
			}
			System.out.print("\t\t");
			
			
		}

	}

}
